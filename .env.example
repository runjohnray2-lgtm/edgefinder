# Kalshi API credentials (RSA-PSS authentication)
# Get these from your Kalshi account settings
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_B64=base64-encoded-pem-private-key-here

# Access codes for the paywall (comma-separated)
# Generate random strings and sell them on Gumroad
ACCESS_CODES=EDGE-XXXX-XXXX,EDGE-YYYY-YYYY
